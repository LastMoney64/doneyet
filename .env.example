# Telegram Bot Token (BotFather에서 발급)
BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 봇 최고 관리자의 Telegram User ID (숫자)
# @userinfobot 에게 메시지 보내면 확인 가능
SUPER_ADMIN_ID=123456789

# 타임존 (기본값: Asia/Seoul)
TIMEZONE=Asia/Seoul

# 아침 알림 시간 (기본값: 9시)
MORNING_HOUR=9
MORNING_MINUTE=0
